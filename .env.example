# Salesforce Developer Edition Credentials
# ─────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to version control — it is in .gitignore
#
# See docs/01-signup-and-setup.md for how to get each value.
# Use User B (integration user) credentials for programmatic access.
# See docs/02-user-setup.md for the two-user setup.

# ── Salesforce user credentials (use User B / integration user) ──
SF_USERNAME=your.email@example.com
SF_PASSWORD=yourpassword
SF_SECURITY_TOKEN=yourSecurityTokenHere

# ── Connected App OAuth credentials ──
# Found at: Setup > Apps > App Manager > (your app) > View > Manage Consumer Details
SF_CONSUMER_KEY=yourConnectedAppConsumerKey
SF_CONSUMER_SECRET=yourConnectedAppConsumerSecret

# ── Instance URL ──
# Your org login URL, e.g. https://myorg.my.salesforce.com
# Returned in the access token response as "instance_url"
SF_INSTANCE_URL=https://login.salesforce.com

# ── API version ──
SF_API_VERSION=v62.0
